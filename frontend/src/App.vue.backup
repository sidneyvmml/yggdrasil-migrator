]

const setSourceEngine = (engineName: string) => {
  if (!selectableEngineNames.value.includes(engineName)) {
    return
  }
  selectedSourceEngine.value = engineName
  if (engineName === 'Keycloak') {
    selectedTargetEngine.value = 'Keycloak'
  } else {
    if (selectedTargetEngine.value === 'Keycloak') {
      selectedTargetEngine.value = ''
    }
  }
  sourceConnection.status = ''
  sourceConnection.message = ''
  sourceConnection.database = ''
  sourceConnection.collection = ''
  sourceDatabases.value = []
  sourceCollections.value = []
  sourceSamples.value = []
  sourceKeycloakConnection.connected = false
  sourceKeycloakConnection.message = ''
  migrationMode.value = 'simple'
}

const setTargetEngine = (engineName: string) => {
  if (!selectableEngineNames.value.includes(engineName)) {
    return
  }
  selectedTargetEngine.value = engineName
  if (engineName === 'Keycloak') {
    selectedSourceEngine.value = 'Keycloak'
  } else {
    if (selectedSourceEngine.value === 'Keycloak') {
      selectedSourceEngine.value = ''
    }
  }
  destinationConnection.status = ''
  destinationConnection.message = ''
  destinationConnection.database = ''
  destinationConnection.collection = ''
  destinationDatabases.value = []
  destinationCollections.value = []
  destinationSamples.value = []
  destinationKeycloakConnection.connected = false
  destinationKeycloakConnection.message = ''
