  background: linear-gradient(180deg, #111827 0%, #1f2937 100%);
  box-shadow: 0 10px 24px rgba(2, 6, 23, 0.35);
}

.migration-flow-copy h2 {
  margin: 0;
  font-size: 1.05rem;
}

.migration-flow-copy p {
  margin: 4px 0 0;
