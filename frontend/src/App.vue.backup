  font-weight: 700;
}

.header {
  display: flex;
  flex-direction: column;
  gap: 16px;
  margin-bottom: 24px;
}

.header h1 {
  margin: 0;
  font-size: 2rem;
}

.header p {
  margin: 0;
  color: #94a3b8;
}

.tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.tab {
  padding: 10px 16px;
  border: 1px solid #334155;
  border-radius: 9999px;
  background: #111827;
  color: #cbd5e1;
  cursor: pointer;
  transition: all 0.2s ease;
}

.tab.active {
  background: rgba(34, 197, 94, 0.18);
  color: #dcfce7;
  border-color: rgba(34, 197, 94, 0.4);
}

.content {
  display: grid;
