  password: '',
})

const previewRows = [
  '{ "name": { "first": "Jane", "last": "Doe" }, "email": "jane@example.com" }',
  '{ "name": { "first": "John", "last": "Smith" }, "email": "john@example.com" }',
]

const sourceResult = computed(() => {
  if (!sourceConnection.status) {
    return null
  }
  return {
    success: sourceConnection.status === 'success',
    message: sourceConnection.message,
  }
})

const destinationResult = computed(() => {
  if (!destinationConnection.status) {
    return null
  }
  return {
    success: destinationConnection.status === 'success',
    message: destinationConnection.message,
  }
})

const testConnection = async (connection: typeof sourceConnection, resultSetter: (status: string, message: string) => void) => {
  connection.testing = true
  connection.status = ''
  connection.message = ''

  try {
    const response = await axios.post('/api/explore/validate', buildMongoConnectionPayload(connection))
    if (response.data.connected) {
      
    } else {
      resultSetter('error', 'Falha ao validar a conexão.')
    }
  } catch (error: any) {
    resultSetter('error', error.response?.data?.detail || error.message || 'Erro na conexão.')
  } finally {
    connection.testing = false
  }
}

const testSourceConnection = async () => {
  await testConnection(sourceConnection, (status, message) => {
    sourceConnection.status = status
    sourceConnection.message = message
  })
}

const testDestinationConnection = async () => {
  await testConnection(destinationConnection, (status, message) => {
    destinationConnection.status = status
    destinationConnection.message = message
  })
}

const buildKeycloakPayload = (connection: typeof sourceKeycloakConnection) => ({
  baseUrl: connection.baseUrl.trim(),
  realm: connection.realm.trim(),
  authMode: connection.authMode,
  clientId: connection.clientId.trim(),
  clientSecret: connection.authMode === 'client_credentials' ? connection.clientSecret : null,
  username: connection.authMode === 'password' ? connection.username.trim() : null,
  password: connection.authMode === 'password' ? connection.password : null,
})

const testKeycloakConnection = async (
  connection: typeof sourceKeycloakConnection,
  applyResult: (connected: boolean, message: string) => void,
) => {
  connection.testing = true
  connection.message = ''
  try {
    const response = await axios.post('/api/keycloak/validate', buildKeycloakPayload(connection))
    if (response.data.connected) {
      applyResult(true, 'Conexao valida com o Keycloak.')
    } else {
      applyResult(false, 'Falha ao validar conexao com Keycloak.')
    }
  } catch (error: any) {
    applyResult(false, error.response?.data?.detail || error.message || 'Falha ao validar conexao com Keycloak.')
  } finally {
    connection.testing = false
  }
}

const testSourceKeycloakConnection = async () => {
  await testKeycloakConnection(sourceKeycloakConnection, (connected, message) => {
    sourceKeycloakConnection.connected = connected
    sourceKeycloakConnection.message = message
  })
}

const testDestinationKeycloakConnection = async () => {
  await testKeycloakConnection(destinationKeycloakConnection, (connected, message) => {
    destinationKeycloakConnection.connected = connected
    destinationKeycloakConnection.message = message
  })
}

const loadSourceKeycloakUsers = async () => {
  sourceSamplesLoading.value = true
  sourceSamples.value = []
  try {
    const response = await axios.post('/api/keycloak/users', {
      ...buildKeycloakPayload(sourceKeycloakConnection),
      limit: 10,
    })
    sourceSamples.value = response.data.items || []
    syncMappingsFromSamples()
    if (sourceDocumentForMapping.value) {
      mappedPreviewDocument.value = buildMappedDocument(sourceDocumentForMapping.value)
    }
  } catch (error: any) {
    sourceKeycloakConnection.message = error.response?.data?.detail || error.message || 'Erro ao carregar usuarios do Keycloak.'
  } finally {
    sourceSamplesLoading.value = false
  }
}

const applyMongoCredentials = (connectionString: string, username: string, password: string) => {
  const user = username.trim()
  const pass = password.trim()
  if (!user && !pass) {
    return connectionString
  }

  const schemeIndex = connectionString.indexOf('://')
  if (schemeIndex < 0) {
    return connectionString
  }

  const prefix = connectionString.slice(0, schemeIndex + 3)
  const rest = connectionString.slice(schemeIndex + 3)
  const hostAndPath = rest.includes('@') ? rest.split('@').slice(1).join('@') : rest

  const encodedUser = encodeURIComponent(user)
  const encodedPass = encodeURIComponent(pass)
  const credentials = user ? `${encodedUser}:${encodedPass}` : `:${encodedPass}`

  return `${prefix}${credentials}@${hostAndPath}`
}

const buildMongoConnectionPayload = (connection: typeof sourceConnection) => ({
  connectionString: connection.authEnabled
    ? applyMongoCredentials(connection.connectionString, connection.username, connection.password)
    : connection.connectionString,
  authSource: connection.authEnabled ? (connection.authSource.trim() || null) : null,
  database: connection.database,
  collection: connection.collection,
})

// Databases and Collections loading
const sourceDatabases = ref<string[]>([])
const sourceDatabasesLoading = ref(false)
const sourceCollections = ref<string[]>([])
const sourceCollectionsLoading = ref(false)
const destinationDatabases = ref<string[]>([])
const destinationDatabasesLoading = ref(false)
const destinationCollections = ref<string[]>([])
const destinationCollectionsLoading = ref(false)

const sourceSamples = ref<any[]>([])
const sourceSamplesLoading = ref(false)
const destinationSamples = ref<any[]>([])
const destinationSamplesLoading = ref(false)
const useSelectedBaseDocument = ref(false)
const selectedSourceBaseDocumentId = ref('')
const sourceBaseDocument = ref<Record<string, any> | null>(null)
const sourceFieldPaths = ref<string[]>([])
const destinationFieldPaths = ref<string[]>([])
type MappingRule = {
  id: string
  sourceField: string
  targetField: string
  editTargetName: boolean
  valueFromField: string
  noSource?: boolean
  ruleType: 'direct' | 'concat'
  concatLeftField: string
  concatRightField: string
  concatSeparator: string
  dbRefEnabled: boolean
  dbRefCollection: string
  dbRefForeignField: string
  defaultValueEnabled: boolean
  defaultValueRaw: string
  isCustom: boolean
}

let _ruleIdSeq = 0
const nextRuleId = () => String(++_ruleIdSeq)

const mappingRows = ref<MappingRule[]>([])
const mappedPreviewDocument = ref<Record<string, any> | null>(null)
const insertMode = ref<'one' | 'all'>('one')
const extractStarredsEnabled = ref(false)
const mergeDocumentsEnabled = ref(false)
const mergeByField = ref('')
const createJobLoading = ref(false)
const createJobError = ref('')

const showAddRuleModal = ref(false)
const addRuleMode = ref<'new' | 'concat'>('new')
const addRuleSourceField = ref('')
const addRuleConcatLeft = ref('')
const addRuleConcatRight = ref('')
const addRuleConcatSeparator = ref(' ')
const addRuleTargetField = ref('')
const addRuleNoSource = ref(false)
const addRuleNoSourceDefaultRaw = ref('')
const addRuleError = ref('')

const showDbRefModal = ref(false)
const dbRefEditingRule = ref<MappingRule | null>(null)
const dbRefEnabledDraft = ref(false)
const dbRefCollectionDraft = ref('')
const dbRefForeignFieldDraft = ref('_id')
const dbRefError = ref('')

const showDefaultValueModal = ref(false)
const defaultValueEditingRule = ref<MappingRule | null>(null)
const defaultValueEnabledDraft = ref(false)
const defaultValueRawDraft = ref('')
const defaultValueError = ref('')

type JobItem = {
  jobId: string
  status: string
  progress: number
  createdAt: string
  updatedAt: string
  canRerun?: boolean
  result?: {
    processed?: number
    inserted?: number
    merged?: number
    skipped?: number
    errors?: Array<{ id?: string; reason?: string }>
    error?: string
  } | null
}

type TemplatePayload = {
  migrationName: string
  source: {
    database: string
    collection: string
  }
  target: {
    database: string
    collection: string
  }
  sourceBaseDocumentId?: string | null
  fieldMapping: Record<string, string>
  manualMapping: Record<string, any>
  concatRules: Array<{ sourceFields: string[]; targetField: string; separator: string }>
  dbRefRules: Array<{ targetField: string; fromCollection: string; foreignField: string }>
  mergeByField: string | null
  lookups: Array<Record<string, any>>
  flattenConfig: Array<{ field: string; mode: 'preserve' | 'explode' }>
  filterRules: Array<{ field: string; op: 'eq' | 'truthy'; value?: any }>
}

type TemplateItem = {
  templateId: number
  name: string
  description?: string | null
  payload: TemplatePayload
  createdAt: string
  updatedAt: string
}

const jobs = ref<JobItem[]>([])
const jobsLoading = ref(false)
const rerunJobLoadingId = ref('')
const deleteJobLoadingId = ref('')
const jobsCurrentPage = ref(1)
const jobsPageSize = ref(10)
const jobsSortBy = ref<'date_desc' | 'date_asc'>('date_desc')
const templates = ref<TemplateItem[]>([])
const templatesLoading = ref(false)
const templatesSaving = ref(false)
const templatesDeletingId = ref<number | null>(null)
const templatesFeedback = ref('')
const templatesFeedbackType = ref<'success' | 'error'>('success')
const templateForm = reactive({
  name: '',
  description: '',
})
const JOB_STAGES = ['pending', 'loading_source', 'mapping_fields', 'inserting_documents', 'done'] as const
let jobsPollTimer: ReturnType<typeof setInterval> | null = null

const jobsSorted = computed(() => {
  const sorted = [...jobs.value]
  if (jobsSortBy.value === 'date_asc') {
    sorted.sort((a, b) => new Date(a.createdAt).getTime() - new Date(b.createdAt).getTime())
  } else {
    sorted.sort((a, b) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime())
  }
  return sorted
})

const jobsPaginated = computed(() => {
  const start = (jobsCurrentPage.value - 1) * jobsPageSize.value
  const end = start + jobsPageSize.value
  return jobsSorted.value.slice(start, end)
})

const jobsTotalPages = computed(() => Math.ceil(jobsSorted.value.length / jobsPageSize.value))

const previewSourceDocument = computed(() => {
  return sourceDocumentForMapping.value
    ? JSON.stringify(sourceDocumentForMapping.value, null, 2)
    : 'Carregue uma amostra da origem para visualizar.'
})

const previewMappedDocument = computed(() => {
  if (sourceDocumentForMapping.value) {
    return JSON.stringify(buildMappedDocument(sourceDocumentForMapping.value), null, 2)
  }
  if (mappedPreviewDocument.value) {
    return JSON.stringify(mappedPreviewDocument.value, null, 2)
  }
  return 'O resultado do mapeamento aparecerá aqui.'
})

const sourceDocumentForMapping = computed<Record<string, any> | null>(() => {
  if (useSelectedBaseDocument.value && sourceBaseDocument.value) {
    return sourceBaseDocument.value
  }
  return sourceSamples.value.length > 0 ? sourceSamples.value[0] : null
})

const getDocumentId = (item: Record<string, any>): string => {
  const rawId = item?._id
  if (!rawId) {
    return ''
  }
  if (typeof rawId === 'string') {
    return rawId
  }
  if (typeof rawId === 'object' && typeof rawId.$oid === 'string') {
    return rawId.$oid
  }
  return ''
}

const selectSourceBaseDocument = (item: Record<string, any>) => {
  const id = getDocumentId(item)
  selectedSourceBaseDocumentId.value = id
  sourceBaseDocument.value = id ? item : null
  syncMappingsFromSamples()
  mappedPreviewDocument.value = sourceDocumentForMapping.value ? buildMappedDocument(sourceDocumentForMapping.value) : null
}

const hasStarredsArray = computed(() => {
  if (sourceSamples.value.length === 0) {
    return false
  }
  const value = readValueByPath(sourceSamples.value[0], 'starreds')
  return Array.isArray(value)
})

const mergeFieldOptions = computed(() => {
  return Array.from(
    new Set(
      mappingRows.value
        .map((row) => row.targetField.trim())
        .filter((field) => field.length > 0)
    )
  )
})

const formatPreviewValue = (value: any) => {
  if (value === undefined) {
    return 'undefined'
  }
  if (value === null) {
    return 'null'
  }
  if (typeof value === 'object') {
    return JSON.stringify(value)
  }
  return String(value)
}

const previewSourceFields = computed(() => {
  if (!sourceDocumentForMapping.value) {
    return []
  }

  return sourceFieldPaths.value.map((path) => ({
    path,
    value: formatPreviewValue(readValueByPath(sourceDocumentForMapping.value, path)),
  }))
})

const previewMappedFields = computed(() => {
  if (!sourceDocumentForMapping.value) {
    return []
  }

  const sourceForPreview = (() => {
    if (!extractStarredsEnabled.value) {
      return sourceDocumentForMapping.value
    }

    const starreds = readValueByPath(sourceDocumentForMapping.value, 'starreds')
    if (!Array.isArray(starreds)) {
      return sourceDocumentForMapping.value
    }

    const firstStarred = starreds.find((entry) => entry && isTruthyStarred(entry.starred))
    if (!firstStarred) {
      return sourceDocumentForMapping.value
    }

    return { ...sourceDocumentForMapping.value, starreds: firstStarred }
  })()

  return mappingRows.value
    .filter((mapping) => mapping.targetField)
    .map((mapping) => {
      const computedValue = mapping.ruleType === 'concat'
        ? [
            readValueByPath(sourceForPreview, mapping.concatLeftField),
            readValueByPath(sourceForPreview, mapping.concatRightField),
          ]
            .filter((item) => item !== null && item !== undefined)
            .map((item) => String(item))
            .join(mapping.concatSeparator)
        : readValueByPath(sourceForPreview, mapping.valueFromField || mapping.sourceField)

      const value = mapping.defaultValueEnabled
        ? normalizeManualValue(mapping.defaultValueRaw)
        : (mapping.dbRefEnabled && mapping.dbRefCollection
          ? { $id: computedValue, $ref: mapping.dbRefCollection }
          : computedValue)

      return {
        path: mapping.targetField,
        value: formatPreviewValue(value),
        mode: mapping.ruleType === 'concat' || mapping.editTargetName ? 'manual' : 'mapped',
      }
    })
})

const mappingTargetOptions = computed(() => {
  if (destinationFieldPaths.value.length > 0) {
    return destinationFieldPaths.value
  }
  return sourceFieldPaths.value
})

const wizardCurrentStep = computed(() => {
  if (activeTab.value === 'engines') {
    return 1
  }
  if (activeTab.value === 'preview') {
    return 5
  }
  if (activeTab.value === 'mapping') {
    return 4
  }
  if (activeTab.value === 'connections') {
    return 3
  }
  return 0
})

const wizardSteps = computed(() => {
  const baseSteps = [
    { key: 'engines', label: 'Database Engines', number: 1 },
    { key: 'setup', label: 'Connection Setup', number: 2 },
    { key: 'source-target', label: 'Source & Target', number: 3 },
    { key: 'mapping', label: 'Field Mapping', number: 4 },
    { key: 'review', label: 'Review & Job', number: 5 },
  ]

  return baseSteps.map((step) => {
    let state = 'upcoming'
    if (wizardCurrentStep.value > 0 && step.number < wizardCurrentStep.value) {
      state = 'completed'
    } else if (step.number === wizardCurrentStep.value) {
      state = 'active'
    }

    return {
      key: step.key,
      label: step.label,
      badge: state === 'completed' ? '✓' : String(step.number),
      state,
    }
  })
})

const typeToClass = (type: string) => {
  const lookup: Record<string, string> = {
    string: 'type-string',
    object: 'type-object',
    date: 'type-date',
    array: 'type-array',
    objectid: 'type-objectid',
    number: 'type-string',
    boolean: 'type-date',
    unknown: 'type-string',
  }
  return lookup[type.toLowerCase()] || 'type-string'
}

const inferValueType = (value: any): string => {
  if (value === null || value === undefined) {
    return 'unknown'
  }
  if (Array.isArray(value)) {
    return 'array'
  }
  if (typeof value === 'string') {
    return 'string'
  }
  if (typeof value === 'number') {
    return 'number'
  }
  if (typeof value === 'boolean') {
    return 'boolean'
  }
  if (typeof value === 'object') {
    if ('$oid' in value || '$binary' in value) {
      return 'objectId'
    }
    if ('$date' in value) {
      return 'date'
    }
    return 'object'
  }
  return 'unknown'
}

const sourceFieldTree = computed(() => {
  return sourceFieldPaths.value.map((path) => {
    const value = sourceDocumentForMapping.value ? readValueByPath(sourceDocumentForMapping.value, path) : undefined
    const type = inferValueType(value)
    return {
      path,
      depth: path.split('.').length - 1,
      type,
      typeClass: typeToClass(type),
    }
  })
})

const targetFieldList = computed(() => {
  const targetPaths = destinationFieldPaths.value.length > 0 ? destinationFieldPaths.value : mappingTargetOptions.value
  const mappedTargets = mappingRows.value
    .map((row) => row.targetField?.trim())
    .filter((field): field is string => Boolean(field))

  const mergedTargets = [...targetPaths]
  for (const mappedTarget of mappedTargets) {
    if (!mergedTargets.includes(mappedTarget)) {
      mergedTargets.push(mappedTarget)
    }
  }

  return mergedTargets.map((path) => {
    const value = destinationSamples.value.length > 0 ? readValueByPath(destinationSamples.value[0], path) : undefined
    const type = inferValueType(value)
    return {
      path,
      type: type === 'unknown' ? 'varchar' : type,
      typeClass: typeToClass(type === 'unknown' ? 'string' : type),
    }
  })
})

const inferTransform = (sourceField: string) => {
  if (sourceField.includes('.$id')) {
    return 'DBRef Resolve'
  }
  if (sourceField.includes('zip') || sourceField.includes('document')) {
    return 'Rename'
  }
  if (sourceField.toLowerCase().includes('date') || sourceField.toLowerCase().includes('created')) {
    return 'Date Format'
  }
  if (sourceField.toLowerCase().includes('tags')) {
    return 'Array to JSON'
  }
  if (sourceField.includes('.')) {
    return 'Extract'
  }
  return 'None'
}

const mappingTableRows = computed(() => {
  return mappingRows.value.map((row, idx) => {
    const sourceValue = sourceDocumentForMapping.value
      ? (
          row.ruleType === 'concat'
            ? [
                readValueByPath(sourceDocumentForMapping.value, row.concatLeftField),
                readValueByPath(sourceDocumentForMapping.value, row.concatRightField),
              ].join(row.concatSeparator)
            : readValueByPath(sourceDocumentForMapping.value, row.valueFromField || row.sourceField)
        )
      : undefined
    const sourceType = inferValueType(sourceValue)
    const typeLabel = `${sourceType} -> varchar`
    const required = idx < 3 || row.sourceField.includes('created') || row.sourceField.includes('zip')
    const hasTarget = Boolean(row.targetField && row.targetField.trim())
    const status = row.defaultValueEnabled && !row.defaultValueRaw.trim()
      ? 'Warning'
      : row.dbRefEnabled && !row.dbRefCollection
      ? 'Warning'
      : (row.sourceField.includes('.$id') ? 'Warning' : (hasTarget ? 'Valid' : 'Optional'))
    const statusClass = status === 'Warning' ? 'warn' : (status === 'Valid' ? 'valid' : 'optional')
    return {
      index: idx + 1,
      isFirst: idx === 0,
      isLast: idx === mappingRows.value.length - 1,
      model: row,
      typeLabel,
      transform: row.defaultValueEnabled
        ? 'Default Value'
        : row.dbRefEnabled
        ? `DBRef ${row.dbRefCollection ? `(${row.dbRefCollection})` : ''}`.trim()
        : (row.ruleType === 'concat' ? 'Concatenate' : inferTransform(row.sourceField)),
      required,
      status,
      statusClass,
    }
  })
})

const toJsonLines = (value: Record<string, any>) => JSON.stringify(value, null, 2).split('\n')

const sourceCodeLines = computed(() => {
  const sample = sourceDocumentForMapping.value || {}
  return toJsonLines(sample)
})

const mappedCodeLines = computed(() => {
  const sample = sourceDocumentForMapping.value || {}
  return toJsonLines(buildMappedDocument(sample))
})

const mappedRequiredCount = computed(() => mappingTableRows.value.filter((row) => row.required && row.model.targetField).length)
const optionalUnmappedCount = computed(() => mappingTableRows.value.filter((row) => !row.required && !row.model.targetField).length)
const hasDbRefWarning = computed(() => mappingRows.value.some((row) => row.dbRefEnabled && !row.dbRefCollection))
const hasDefaultValueWarning = computed(() => mappingRows.value.some((row) => row.defaultValueEnabled && !row.defaultValueRaw.trim()))

const extractFieldPaths = (value: any, prefix = ''): string[] => {
  if (value === null || value === undefined) {
    return prefix ? [prefix] : []
  }

  if (Array.isArray(value)) {
    if (value.length === 0) {
      return prefix ? [prefix] : []
    }
    const nestedPaths = extractFieldPaths(value[0], prefix)
    return nestedPaths.length > 0 ? nestedPaths : prefix ? [prefix] : []
  }

  if (typeof value !== 'object') {
    return prefix ? [prefix] : []
  }

  // Treat Extended JSON/BSON helper objects (keys like $binary, $date) as leaf values.
  const keys = Object.keys(value)
  if (keys.some((key) => key.startsWith('$'))) {
    return prefix ? [prefix] : []
  }

  const paths: string[] = []
  for (const [key, childValue] of Object.entries(value)) {
    const nextPrefix = prefix ? `${prefix}.${key}` : key
    const childPaths = extractFieldPaths(childValue, nextPrefix)
    if (childPaths.length === 0) {
      paths.push(nextPrefix)
    } else {
      paths.push(...childPaths)
    }
  }
  return paths
}

const syncMappingsFromSamples = () => {
  sourceFieldPaths.value = sourceDocumentForMapping.value ? extractFieldPaths(sourceDocumentForMapping.value) : []
  destinationFieldPaths.value = destinationSamples.value.length > 0 ? extractFieldPaths(destinationSamples.value[0]) : []
  const destinationHasSchema = destinationFieldPaths.value.length > 0

  const customRules = mappingRows.value.filter((item) => item.isCustom)
  const currentMappings = new Map(mappingRows.value.filter((item) => !item.isCustom).map((item) => [item.sourceField, item.targetField]))
  const currentEditTargetFlags = new Map(mappingRows.value.filter((item) => !item.isCustom).map((item) => [item.sourceField, item.editTargetName]))
  const currentValueFromFields = new Map(mappingRows.value.filter((item) => !item.isCustom).map((item) => [item.sourceField, item.valueFromField]))
  const currentDbRefEnabled = new Map(mappingRows.value.filter((item) => !item.isCustom).map((item) => [item.sourceField, item.dbRefEnabled]))
  const currentDbRefCollection = new Map(mappingRows.value.filter((item) => !item.isCustom).map((item) => [item.sourceField, item.dbRefCollection]))
  const currentDbRefForeignField = new Map(mappingRows.value.filter((item) => !item.isCustom).map((item) => [item.sourceField, item.dbRefForeignField]))
  const currentDefaultEnabled = new Map(mappingRows.value.filter((item) => !item.isCustom).map((item) => [item.sourceField, item.defaultValueEnabled]))
  const currentDefaultRaw = new Map(mappingRows.value.filter((item) => !item.isCustom).map((item) => [item.sourceField, item.defaultValueRaw]))
  const currentIds = new Map(mappingRows.value.filter((item) => !item.isCustom).map((item) => [item.sourceField, item.id]))

  const directRules = sourceFieldPaths.value.map((field) => ({
    id: currentIds.get(field) ?? nextRuleId(),
    sourceField: field,
    targetField: currentMappings.get(field) ?? (destinationHasSchema ? (destinationFieldPaths.value.includes(field) ? field : '') : field),
    editTargetName: currentEditTargetFlags.get(field) ?? false,
    valueFromField: currentValueFromFields.get(field) ?? field,
    ruleType: 'direct' as const,
    concatLeftField: '',
    concatRightField: '',
    concatSeparator: ' ',
    dbRefEnabled: currentDbRefEnabled.get(field) ?? false,
    dbRefCollection: currentDbRefCollection.get(field) ?? '',
    dbRefForeignField: currentDbRefForeignField.get(field) ?? '_id',
    defaultValueEnabled: currentDefaultEnabled.get(field) ?? false,
    defaultValueRaw: currentDefaultRaw.get(field) ?? '',
    isCustom: false,
  }))

  const filteredCustomRules = customRules.filter((rule) => {
    if (rule.noSource) {
      return true
    }
    if (rule.ruleType === 'concat') {
      return sourceFieldPaths.value.includes(rule.concatLeftField) && sourceFieldPaths.value.includes(rule.concatRightField)
    }
    return sourceFieldPaths.value.includes(rule.valueFromField)
  })

  mappingRows.value = [...directRules, ...filteredCustomRules]
}

const openAddRuleModal = () => {
  showAddRuleModal.value = true
  addRuleError.value = ''
  addRuleMode.value = 'new'
  addRuleSourceField.value = sourceFieldPaths.value[0] || ''
  addRuleConcatLeft.value = sourceFieldPaths.value[0] || ''
  addRuleConcatRight.value = sourceFieldPaths.value[1] || sourceFieldPaths.value[0] || ''
  addRuleConcatSeparator.value = ' '
  addRuleTargetField.value = ''
  addRuleNoSource.value = false
  addRuleNoSourceDefaultRaw.value = ''
}

const closeAddRuleModal = () => {
  showAddRuleModal.value = false
  addRuleError.value = ''
}

const submitAddRule = () => {
  addRuleError.value = ''
  const targetField = addRuleTargetField.value.trim()
  if (!targetField) {
    addRuleError.value = 'Informe o nome do campo no target.'
    return
  }

  if (mappingRows.value.some((item) => item.targetField === targetField)) {
    addRuleError.value = 'Ja existe uma regra para esse campo target.'
    return
  }

  if (addRuleMode.value === 'new') {
    if (addRuleNoSource.value) {
      const defaultRaw = addRuleNoSourceDefaultRaw.value.trim()
      if (!defaultRaw) {
        addRuleError.value = 'Informe o valor padrao para o campo novo.'
        return
      }

      mappingRows.value.push({
        id: nextRuleId(),
        sourceField: '(novo)',
        targetField,
        editTargetName: true,
        valueFromField: '',
        noSource: true,
        ruleType: 'direct',
        concatLeftField: '',
        concatRightField: '',
        concatSeparator: ' ',
        dbRefEnabled: false,
        dbRefCollection: '',
        dbRefForeignField: '_id',
        defaultValueEnabled: true,
        defaultValueRaw: addRuleNoSourceDefaultRaw.value,
        isCustom: true,
      })
      closeAddRuleModal()
      return
    }

    if (!sourceFieldPaths.value.includes(addRuleSourceField.value)) {
      addRuleError.value = 'Campo de origem invalido.'
      return
    }

    mappingRows.value.push({
      id: nextRuleId(),
      sourceField: addRuleSourceField.value,
      targetField,
      editTargetName: true,
      valueFromField: addRuleSourceField.value,
      noSource: false,
      ruleType: 'direct',
      concatLeftField: '',
      concatRightField: '',
      concatSeparator: ' ',
      dbRefEnabled: false,
      dbRefCollection: '',
      dbRefForeignField: '_id',
      defaultValueEnabled: false,
      defaultValueRaw: '',
      isCustom: true,
    })
    closeAddRuleModal()
    return
  }

  if (!sourceFieldPaths.value.includes(addRuleConcatLeft.value) || !sourceFieldPaths.value.includes(addRuleConcatRight.value)) {
    addRuleError.value = 'Campos para concatenacao invalidos.'
    return
  }

  mappingRows.value.push({
    id: nextRuleId(),
    sourceField: `${addRuleConcatLeft.value} + ${addRuleConcatRight.value}`,
    targetField,
    editTargetName: true,
    valueFromField: addRuleConcatLeft.value,
    noSource: false,
    ruleType: 'concat',
    concatLeftField: addRuleConcatLeft.value,
    concatRightField: addRuleConcatRight.value,
    concatSeparator: addRuleConcatSeparator.value,
    dbRefEnabled: false,
    dbRefCollection: '',
    dbRefForeignField: '_id',
    defaultValueEnabled: false,
    defaultValueRaw: '',
    isCustom: true,
  })
  closeAddRuleModal()
}

const moveMappingRule = (rowIndex: number, direction: -1 | 1) => {
  const targetIndex = rowIndex + direction
  if (rowIndex < 0 || rowIndex >= mappingRows.value.length || targetIndex < 0 || targetIndex >= mappingRows.value.length) {
    return
  }

  const [rule] = mappingRows.value.splice(rowIndex, 1)
  if (!rule) {
    return
  }
  mappingRows.value.splice(targetIndex, 0, rule)
}

const removeRule = (rule: MappingRule) => {
  if (!rule.isCustom) {
    rule.targetField = ''
    rule.valueFromField = rule.sourceField
    rule.dbRefEnabled = false
    rule.dbRefCollection = ''
    rule.dbRefForeignField = '_id'
    rule.defaultValueEnabled = false
    rule.defaultValueRaw = ''
    rule.noSource = false
    return
  }
  mappingRows.value = mappingRows.value.filter((item) => item !== rule)
}

const openDbRefModal = (rule: MappingRule) => {
  dbRefEditingRule.value = rule
  dbRefEnabledDraft.value = rule.dbRefEnabled
  dbRefCollectionDraft.value = rule.dbRefCollection || ''
  dbRefForeignFieldDraft.value = rule.dbRefForeignField || '_id'
  dbRefError.value = ''
  showDbRefModal.value = true
}

const closeDbRefModal = () => {
  showDbRefModal.value = false
  dbRefEditingRule.value = null
  dbRefError.value = ''
}

const saveDbRefRule = () => {
  const rule = dbRefEditingRule.value
  if (!rule) {
    closeDbRefModal()
    return
  }

  if (dbRefEnabledDraft.value && !dbRefCollectionDraft.value.trim()) {
    dbRefError.value = 'Informe a collection de referencia para DBRef.'
    return
  }

  rule.dbRefEnabled = dbRefEnabledDraft.value
  rule.dbRefCollection = dbRefCollectionDraft.value.trim()
  rule.dbRefForeignField = (dbRefForeignFieldDraft.value || '_id').trim()
  closeDbRefModal()
}

const openDefaultValueModal = (rule: MappingRule) => {
  defaultValueEditingRule.value = rule
  defaultValueEnabledDraft.value = rule.defaultValueEnabled
  defaultValueRawDraft.value = rule.defaultValueRaw || ''
  defaultValueError.value = ''
  showDefaultValueModal.value = true
}

const closeDefaultValueModal = () => {
  showDefaultValueModal.value = false
  defaultValueEditingRule.value = null
  defaultValueError.value = ''
}

const saveDefaultValueRule = () => {
  const rule = defaultValueEditingRule.value
  if (!rule) {
    closeDefaultValueModal()
    return
  }

  if (defaultValueEnabledDraft.value && !defaultValueRawDraft.value.trim()) {
    defaultValueError.value = 'Informe o valor padrao para este campo.'
    return
  }

  rule.defaultValueEnabled = defaultValueEnabledDraft.value
  rule.defaultValueRaw = defaultValueRawDraft.value
  closeDefaultValueModal()
}

const normalizeManualValue = (value: string) => {
  const trimmedValue = value.trim()
  if (trimmedValue === '') {
    return ''
  }

  if (trimmedValue === 'true') {
    return true
  }

  if (trimmedValue === 'false') {
    return false
  }

  if (/^-?\d+(\.\d+)?$/.test(trimmedValue)) {
    return Number(trimmedValue)
  }

  if (
    (trimmedValue.startsWith('{') && trimmedValue.endsWith('}')) ||
    (trimmedValue.startsWith('[') && trimmedValue.endsWith(']')) ||
    (trimmedValue.startsWith('"') && trimmedValue.endsWith('"'))
  ) {
    try {
      return JSON.parse(trimmedValue)
    } catch {
      return value
    }
  }

  return value
}

const readValueByPath = (value: any, path: string) => {
  return path.split('.').reduce((currentValue, segment) => {
    if (currentValue === null || currentValue === undefined) {
      return undefined
    }
    return currentValue[segment]
  }, value)
}

const isTruthyStarred = (value: any) => {
  if (typeof value === 'boolean') {
    return value
  }
  if (typeof value === 'number') {
    return value !== 0
  }
  if (typeof value === 'string') {
    return ['true', '1', 'yes', 'y', 'on'].includes(value.trim().toLowerCase())
  }
  return Boolean(value)
}

const writeValueByPath = (target: Record<string, any>, path: string, value: any) => {
  const segments = path.split('.')
  let cursor = target

  for (let index = 0; index < segments.length; index += 1) {
    const segment = segments[index]
    const isLastSegment = index === segments.length - 1

    if (isLastSegment) {
      cursor[segment] = value
      return
    }

    if (!cursor[segment] || typeof cursor[segment] !== 'object') {
      cursor[segment] = {}
    }

    cursor = cursor[segment]
  }
}

const buildMappedDocument = (sourceDocument: Record<string, any>) => {
  const mappedDocument: Record<string, any> = {}

  for (const mapping of mappingRows.value) {
    if (!mapping.targetField) {
      continue
    }

    const computedValue = mapping.ruleType === 'concat'
      ? [
          readValueByPath(sourceDocument, mapping.concatLeftField),
          readValueByPath(sourceDocument, mapping.concatRightField),
        ]
          .filter((item) => item !== null && item !== undefined)
          .map((item) => String(item))
          .join(mapping.concatSeparator)
      : readValueByPath(sourceDocument, mapping.valueFromField || mapping.sourceField)

    const targetField = mapping.targetField
    const fieldValue = mapping.defaultValueEnabled
      ? normalizeManualValue(mapping.defaultValueRaw)
      : computedValue

    if (mapping.dbRefEnabled && mapping.dbRefCollection) {
      writeValueByPath(mappedDocument, targetField, {
        $id: fieldValue,
        $ref: mapping.dbRefCollection,
      })
    } else {
      writeValueByPath(mappedDocument, targetField, fieldValue)
    }
  }

  if (extractStarredsEnabled.value) {
    const now = new Date().toISOString()
    if (mappedDocument._class === undefined) {
      mappedDocument._class = 'Favorites'
    }
    if (mappedDocument.createdAt === undefined) {
      mappedDocument.createdAt = now
    }
    if (mappedDocument.updatedAt === undefined) {
      mappedDocument.updatedAt = now
    }
  }

  return mappedDocument
}

const buildMappedDocuments = (sourceDocument: Record<string, any>) => {
  if (!extractStarredsEnabled.value) {
    return [buildMappedDocument(sourceDocument)]
  }

  const starreds = readValueByPath(sourceDocument, 'starreds')
  if (!Array.isArray(starreds)) {
    return [buildMappedDocument(sourceDocument)]
  }

  return starreds
    .filter((entry) => entry && isTruthyStarred(entry.starred))
    .map((entry) => ({ ...sourceDocument, starreds: entry }))
    .map((expandedSource) => buildMappedDocument(expandedSource))
}

const mapData = () => {
  if (!sourceDocumentForMapping.value) {
    mappedPreviewDocument.value = null
    activeTab.value = 'preview'
    return
  }

  const mappedDocs = buildMappedDocuments(sourceDocumentForMapping.value)
  mappedPreviewDocument.value = mappedDocs.length > 0 ? mappedDocs[0] : null
  activeTab.value = 'preview'
}

const normalizeJobStatus = (status: string) => {
  if (JOB_STAGES.includes(status as (typeof JOB_STAGES)[number])) {
    return status
  }
  if (status === 'running') {
    return 'inserting_documents'
  }
  return status
}

const statusLabel = (status: string) => {
  const normalized = normalizeJobStatus(status)
  const labels: Record<string, string> = {
    pending: 'pending',
    loading_source: 'loading source',
    mapping_fields: 'mapping fields',
    inserting_documents: 'inserting documents',
    done: 'done',
    failed: 'failed',
  }
  return labels[normalized] || normalized
}

const stageLabel = (stage: string) => {
  const labels: Record<string, string> = {
    pending: 'Queue',
    loading_source: 'Source load',
    mapping_fields: 'Mapping',
    inserting_documents: 'Insert',
    done: 'Done',
  }
  return labels[stage] || stage
}

const stageState = (job: JobItem, stage: string) => {
  const normalized = normalizeJobStatus(job.status)
  const currentIdx = JOB_STAGES.indexOf(normalized as (typeof JOB_STAGES)[number])
  const stageIdx = JOB_STAGES.indexOf(stage as (typeof JOB_STAGES)[number])

  if (normalized === 'failed') {
    return 'pending'
  }

  if (currentIdx === -1 || stageIdx === -1) {
    return 'pending'
  }

  if (stageIdx < currentIdx) {
    return 'done'
  }

  if (stageIdx === currentIdx) {
    return normalized === 'done' ? 'done' : 'active'
  }

  return 'pending'
}

const jobNoOutputHint = (job: JobItem) => {
  const result = job.result
  if (!result) {
    return ''
  }

  const processed = result.processed ?? 0
  const inserted = result.inserted ?? 0
  const merged = result.merged ?? 0
  const skipped = result.skipped ?? 0

  if (processed > 0 && inserted === 0 && merged === 0) {
    if (skipped > 0) {
      return 'Nenhum documento novo foi gravado. Todos foram ignorados (ex.: duplicidade de chave).'
    }
    return 'Nenhum documento foi gerado para insercao. Revise filtros/flatten e os campos mapeados (ex.: starreds.position e starreds.service).'
  }

  return ''
}

const hasActiveJobs = computed(() => jobs.value.some((job) => !['done', 'failed'].includes(normalizeJobStatus(job.status))))

const stopJobsPolling = () => {
  if (jobsPollTimer) {
    clearInterval(jobsPollTimer)
    jobsPollTimer = null
  }
}

const startJobsPolling = () => {
  if (jobsPollTimer) {
    return
  }
  jobsPollTimer = setInterval(() => {
    loadJobs(false)
  }, 2000)
}

const buildMigrationConfig = () => {
  const fieldMapping: Record<string, string> = {}
  const manualMapping: Record<string, any> = {}
  const concatRules: Array<{ sourceFields: string[]; targetField: string; separator: string }> = []
  const dbRefRules: Array<{ targetField: string; fromCollection: string; foreignField: string }> = []
  const flattenConfig: Array<{ field: string; mode: 'preserve' | 'explode' }> = []
  const filterRules: Array<{ field: string; op: 'eq' | 'truthy'; value?: any }> = []

  for (const row of mappingRows.value) {
    const targetField = row.targetField.trim()
    if (!targetField) {
      continue
    }

    if (row.defaultValueEnabled) {
      manualMapping[targetField] = normalizeManualValue(row.defaultValueRaw)
      continue
    }

    if (row.ruleType === 'concat') {
      concatRules.push({
        sourceFields: [row.concatLeftField, row.concatRightField],
        targetField,
        separator: row.concatSeparator,
      })
      if (row.dbRefEnabled && row.dbRefCollection) {
        dbRefRules.push({
          targetField,
          fromCollection: row.dbRefCollection,
          foreignField: row.dbRefForeignField || '_id',
        })
      }
      continue
    }

    const valueFromField = (row.valueFromField || row.sourceField).trim()
    if (!valueFromField) {
      continue
    }

    fieldMapping[valueFromField] = targetField
    if (row.dbRefEnabled && row.dbRefCollection) {
      dbRefRules.push({
        targetField,
        fromCollection: row.dbRefCollection,
        foreignField: row.dbRefForeignField || '_id',
      })
    }
  }

  if (extractStarredsEnabled.value && hasStarredsArray.value) {
    flattenConfig.push({ field: 'starreds', mode: 'explode' })
    filterRules.push({ field: 'starreds.starred', op: 'eq', value: true })
    if (manualMapping._class === undefined) {
      manualMapping._class = 'Favorites'
    }
    const now = new Date().toISOString()
    if (manualMapping.createdAt === undefined) {
      manualMapping.createdAt = now
    }
    if (manualMapping.updatedAt === undefined) {
      manualMapping.updatedAt = now
    }
  }

  return {
    migrationName: `Migracao ${new Date().toISOString()}`,
    source: {
      connectionString: buildMongoConnectionPayload(sourceConnection).connectionString,
      database: sourceConnection.database,
      collection: sourceConnection.collection,
      authSource: buildMongoConnectionPayload(sourceConnection).authSource,
    },
    target: {
      connectionString: buildMongoConnectionPayload(destinationConnection).connectionString,
      database: destinationConnection.database,
      collection: destinationConnection.collection,
      authSource: buildMongoConnectionPayload(destinationConnection).authSource,
    },
    sourceBaseDocumentId: useSelectedBaseDocument.value ? (selectedSourceBaseDocumentId.value || null) : null,
    fieldMapping,
    manualMapping,
    concatRules,
    dbRefRules,
    mergeByField: mergeDocumentsEnabled.value ? mergeByField.value.trim() : null,
    lookups: [],
    flattenConfig,
    filterRules,
  }
}

const buildKeycloakMigrationConfig = () => {
  const fieldMapping: Record<string, string> = {}
  for (const row of mappingRows.value) {
    const sourceField = (row.valueFromField || row.sourceField || '').trim()
    const targetField = (row.targetField || '').trim()
    if (!sourceField || !targetField || row.ruleType !== 'direct' || row.noSource) {
      continue
    }
    fieldMapping[sourceField] = targetField
  }

  return {
    migrationType: 'keycloak',
    migrationName: `Migracao Keycloak ${new Date().toISOString()}`,
    source: buildKeycloakPayload(sourceKeycloakConnection),
    target: buildKeycloakPayload(destinationKeycloakConnection),
    usernameSourceField: keycloakUsernameSourceField.value || 'username',
    fieldMapping,
  }
}

const loadJobs = async (showLoading = true) => {
  if (showLoading) {
    jobsLoading.value = true
  }
  try {
    const response = await axios.get('/api/jobs/')
    jobs.value = response.data || []
  } catch {
    // Keep previous jobs if polling fails.
  } finally {
    if (showLoading) {
      jobsLoading.value = false
    }
  }
}

const rerunJob = async (jobId: string) => {
  rerunJobLoadingId.value = jobId
  try {
    await axios.post(`/api/jobs/${jobId}/rerun`)
    await loadJobs(false)
  } catch (error: any) {
    createJobError.value = error.response?.data?.detail || error.message || 'Falha ao reenviar o job.'
    activeTab.value = 'preview'
  } finally {
    rerunJobLoadingId.value = ''
  }
}

const deleteJob = async (jobId: string) => {
  if (!window.confirm('Remover este job da lista?')) {
    return
  }

  deleteJobLoadingId.value = jobId
  try {
    await axios.delete(`/api/jobs/${jobId}`)
    jobs.value = jobs.value.filter((job) => job.jobId !== jobId)
  } catch (error: any) {
    createJobError.value = error.response?.data?.detail || error.message || 'Falha ao remover o job.'
    activeTab.value = 'preview'
  } finally {
    deleteJobLoadingId.value = ''
  }
}

const createInsertJob = async () => {
  createJobError.value = ''

  if (selectedSourceEngine.value === 'Keycloak' && selectedTargetEngine.value === 'Keycloak') {
    if (!sourceKeycloakConnection.connected || !destinationKeycloakConnection.connected) {
      createJobError.value = 'Conecte e valide source e target Keycloak antes de executar.'
      return
    }
    if (!keycloakUsernameSourceField.value.trim()) {
      createJobError.value = 'Selecione o campo de origem para username.'
      return
    }

    createJobLoading.value = true
    try {
      await axios.post('/api/keycloak/execute', {
        config: buildKeycloakMigrationConfig(),
        maxDocuments: insertMode.value === 'one' ? 1 : null,
      })
      await loadJobs(false)
      activeTab.value = 'jobs'
      startJobsPolling()
    } catch (error: any) {
      createJobError.value = error.response?.data?.detail || error.message || 'Falha ao criar job de migracao Keycloak.'
    } finally {
      createJobLoading.value = false
    }
    return
  }

  if (!sourceConnection.database || !sourceConnection.collection) {
    createJobError.value = 'Selecione database e collection de origem.'
    return
  }
  if (!destinationConnection.database || !destinationConnection.collection) {
    createJobError.value = 'Selecione database e collection de destino.'
    return
  }

  const config = buildMigrationConfig()
  if (Object.keys(config.fieldMapping).length === 0 && Object.keys(config.manualMapping).length === 0 && config.concatRules.length === 0) {
    createJobError.value = 'Configure ao menos um mapeamento antes de inserir.'
    return
  }
  if (mergeDocumentsEnabled.value && !mergeByField.value.trim()) {
    createJobError.value = 'Selecione o campo de mesclagem.'
    return
  }

  createJobLoading.value = true
  try {
    await axios.post('/api/migration/execute', {
      config,
      maxDocuments: insertMode.value === 'one' ? 1 : null,
    })
    await loadJobs(false)
    activeTab.value = 'jobs'
    startJobsPolling()
  } catch (error: any) {
    createJobError.value = error.response?.data?.detail || error.message || 'Falha ao criar job de insercao.'
  } finally {
    createJobLoading.value = false
  }
}

const formatTemplateDate = (value: string) => {
  const date = new Date(value)
  if (Number.isNaN(date.getTime())) {
    return value
  }
  return date.toLocaleString('pt-BR')
}

const loadTemplates = async () => {
  templatesLoading.value = true
  try {
    const response = await axios.get('/api/templates/')
    templates.value = response.data || []
  } catch (error: any) {
    templatesFeedbackType.value = 'error'
    templatesFeedback.value = error.response?.data?.detail || error.message || 'Falha ao carregar templates.'
  } finally {
    templatesLoading.value = false
  }
}

const buildTemplatePayloadFromCurrent = (): TemplatePayload => {
  const config = buildMigrationConfig()
  return {
    migrationName: config.migrationName,
    source: {
      database: config.source.database,
      collection: config.source.collection,
    },
    target: {
      database: config.target.database,
      collection: config.target.collection,
    },
    sourceBaseDocumentId: config.sourceBaseDocumentId,
    fieldMapping: config.fieldMapping,
    manualMapping: config.manualMapping,
    concatRules: config.concatRules,
    dbRefRules: config.dbRefRules,
    mergeByField: config.mergeByField,
    lookups: config.lookups,
    flattenConfig: config.flattenConfig,
    filterRules: config.filterRules,
  }
}

const saveCurrentTemplate = async () => {
  templatesFeedback.value = ''
  if (selectedSourceEngine.value === 'Keycloak' || selectedTargetEngine.value === 'Keycloak') {
    templatesFeedbackType.value = 'error'
    templatesFeedback.value = 'Templates para fluxo Keycloak ainda nao estao disponiveis nesta etapa.'
    return
  }
  const name = templateForm.name.trim()
  if (!name) {
    templatesFeedbackType.value = 'error'
    templatesFeedback.value = 'Informe o nome do template.'
    return
  }

  const payload = buildTemplatePayloadFromCurrent()
  if (Object.keys(payload.fieldMapping).length === 0 && Object.keys(payload.manualMapping).length === 0 && payload.concatRules.length === 0) {
    templatesFeedbackType.value = 'error'
    templatesFeedback.value = 'Defina ao menos um mapeamento antes de salvar o template.'
    return
  }

  templatesSaving.value = true
  try {
    await axios.post('/api/templates/', {
      name,
      description: templateForm.description.trim() || null,
      payload,
    })
    templatesFeedbackType.value = 'success'
    templatesFeedback.value = 'Template salvo com sucesso.'
    await loadTemplates()
  } catch (error: any) {
    templatesFeedbackType.value = 'error'
    templatesFeedback.value = error.response?.data?.detail || error.message || 'Falha ao salvar template.'
  } finally {
    templatesSaving.value = false
  }
}

const buildDbRefRuleMap = (
  dbRefRules: Array<{ targetField: string; fromCollection: string; foreignField: string }>
) => new Map(dbRefRules.map((rule) => [rule.targetField, rule]))

const applyTemplatePayload = (payload: TemplatePayload) => {
  sourceConnection.database = payload.source.database || ''
  sourceConnection.collection = payload.source.collection || ''
  destinationConnection.database = payload.target.database || ''
  destinationConnection.collection = payload.target.collection || ''

  mergeByField.value = payload.mergeByField || ''
  mergeDocumentsEnabled.value = Boolean(payload.mergeByField)

  const hasStarredsFlatten = payload.flattenConfig.some((rule) => rule.field === 'starreds' && rule.mode === 'explode')
  const hasStarredsFilter = payload.filterRules.some((rule) => rule.field === 'starreds.starred' && rule.op === 'eq' && rule.value === true)
  extractStarredsEnabled.value = hasStarredsFlatten && hasStarredsFilter

  const dbRefByTarget = buildDbRefRuleMap(payload.dbRefRules || [])
  const importedRows: MappingRule[] = []

  for (const [sourceField, targetField] of Object.entries(payload.fieldMapping || {})) {
    const dbRefRule = dbRefByTarget.get(targetField)
    importedRows.push({
      id: nextRuleId(),
      sourceField,
      targetField,
      editTargetName: sourceField !== targetField,
      valueFromField: sourceField,
      noSource: false,
      ruleType: 'direct',
      concatLeftField: '',
      concatRightField: '',
      concatSeparator: ' ',
      dbRefEnabled: Boolean(dbRefRule),
      dbRefCollection: dbRefRule?.fromCollection || '',
      dbRefForeignField: dbRefRule?.foreignField || '_id',
      defaultValueEnabled: false,
      defaultValueRaw: '',
      isCustom: false,
    })
  }

  for (const [targetField, manualValue] of Object.entries(payload.manualMapping || {})) {
    importedRows.push({
      id: nextRuleId(),
      sourceField: '(novo)',
      targetField,
      editTargetName: true,
      valueFromField: '',
      noSource: true,
      ruleType: 'direct',
      concatLeftField: '',
      concatRightField: '',
      concatSeparator: ' ',
      dbRefEnabled: false,
      dbRefCollection: '',
      dbRefForeignField: '_id',
      defaultValueEnabled: true,
      defaultValueRaw: typeof manualValue === 'string' ? manualValue : JSON.stringify(manualValue),
      isCustom: true,
    })
  }

  for (const concatRule of payload.concatRules || []) {
    const targetField = concatRule.targetField
    const dbRefRule = dbRefByTarget.get(targetField)
    importedRows.push({
      id: nextRuleId(),
      sourceField: `${concatRule.sourceFields[0] || ''} + ${concatRule.sourceFields[1] || ''}`,
      targetField,
      editTargetName: true,
      valueFromField: concatRule.sourceFields[0] || '',
      noSource: false,
      ruleType: 'concat',
      concatLeftField: concatRule.sourceFields[0] || '',
      concatRightField: concatRule.sourceFields[1] || '',
      concatSeparator: concatRule.separator ?? ' ',
      dbRefEnabled: Boolean(dbRefRule),
      dbRefCollection: dbRefRule?.fromCollection || '',
      dbRefForeignField: dbRefRule?.foreignField || '_id',
      defaultValueEnabled: false,
      defaultValueRaw: '',
      isCustom: true,
    })
  }

  mappingRows.value = importedRows

  const discoveredSourceFields = Array.from(
    new Set(
      importedRows
        .flatMap((row) => (row.ruleType === 'concat' ? [row.concatLeftField, row.concatRightField] : [row.valueFromField || row.sourceField]))
        .map((field) => field.trim())
        .filter((field) => field && field !== '(novo)')
    )
  )
  if (sourceFieldPaths.value.length === 0) {
    sourceFieldPaths.value = discoveredSourceFields
  }

  const discoveredTargetFields = Array.from(new Set(importedRows.map((row) => row.targetField.trim()).filter((field) => field.length > 0)))
  if (destinationFieldPaths.value.length === 0) {
    destinationFieldPaths.value = discoveredTargetFields
  }

  const savedDocumentId = payload.sourceBaseDocumentId || ''
  selectedSourceBaseDocumentId.value = savedDocumentId
  useSelectedBaseDocument.value = Boolean(savedDocumentId)
}

const loadSourceBaseDocumentById = async (documentId: string) => {
  if (!documentId || !sourceConnection.database || !sourceConnection.collection) {
    return
  }
  try {
    const response = await axios.post('/api/explore/document', {
      ...buildMongoConnectionPayload(sourceConnection),
      database: sourceConnection.database,
      collection: sourceConnection.collection,
      documentId,
    })
    sourceBaseDocument.value = response.data.item || null
  } catch {
    sourceBaseDocument.value = null
  }
}

const applyTemplate = async (templateItem: TemplateItem) => {
  applyTemplatePayload(templateItem.payload)
  templateForm.name = templateItem.name
  templateForm.description = templateItem.description || ''

  if (selectedSourceBaseDocumentId.value) {
    const fromSampleList = sourceSamples.value.find((item) => getDocumentId(item) === selectedSourceBaseDocumentId.value)
    if (fromSampleList) {
      sourceBaseDocument.value = fromSampleList
    } else {
      await loadSourceBaseDocumentById(selectedSourceBaseDocumentId.value)
    }
  } else {
    sourceBaseDocument.value = null
  }

  syncMappingsFromSamples()
  mappedPreviewDocument.value = sourceDocumentForMapping.value ? buildMappedDocument(sourceDocumentForMapping.value) : null
  templatesFeedbackType.value = 'success'
  templatesFeedback.value = 'Template carregado no fluxo atual.'
  activeTab.value = 'connections'
}

const deleteTemplate = async (templateId: number) => {
  if (!window.confirm('Excluir este template?')) {
    return
  }
  templatesDeletingId.value = templateId
  try {
    await axios.delete(`/api/templates/${templateId}`)
    templates.value = templates.value.filter((item) => item.templateId !== templateId)
  } catch (error: any) {
    templatesFeedbackType.value = 'error'
    templatesFeedback.value = error.response?.data?.detail || error.message || 'Falha ao excluir template.'
  } finally {
    templatesDeletingId.value = null
  }
}

const openTemplatesForCurrentMigration = async () => {
  activeTab.value = 'templates'
  if (!templateForm.name.trim()) {
    templateForm.name = `Template ${new Date().toLocaleString('pt-BR')}`
  }
  await loadTemplates()
}

watch(
  () => activeTab.value,
  (tab) => {
    if (tab === 'templates') {
      loadTemplates()
    }
    if (tab === 'jobs') {
      loadJobs(true)
      startJobsPolling()
      return
    }
    if (!hasActiveJobs.value) {
      stopJobsPolling()
    }
  }
)

watch(
  () => useSelectedBaseDocument.value,
  (enabled) => {
    if (!enabled) {
      selectedSourceBaseDocumentId.value = ''
      sourceBaseDocument.value = null
      syncMappingsFromSamples()
      return
    }

    if (sourceSamples.value.length > 0 && !sourceBaseDocument.value) {
      const firstWithId = sourceSamples.value.find((item) => getDocumentId(item))
      if (firstWithId) {
        selectSourceBaseDocument(firstWithId)
      }
    }
  }
)

watch(
  () => [sourceConnection.database, sourceConnection.collection],
  () => {
    selectedSourceBaseDocumentId.value = ''
    sourceBaseDocument.value = null
    useSelectedBaseDocument.value = false
  }
)

watch(
  () => hasActiveJobs.value,
  (active) => {
    if (active) {
      startJobsPolling()
      return
    }
    if (activeTab.value !== 'jobs') {
      stopJobsPolling()
    }
  }
)

onBeforeUnmount(() => {
  stopJobsPolling()
})

const loadSourceDatabases = async () => {
  sourceDatabasesLoading.value = true
  try {
    const resp = await axios.post('/api/explore/databases', {
      ...buildMongoConnectionPayload(sourceConnection),
      database: 'admin',
      collection: 'admin',
    })
    sourceDatabases.value = resp.data.databases || []
  } catch (err: any) {
    sourceConnection.message = 'Erro ao carregar bancos de dados.'
    sourceConnection.status = 'error'
  } finally {
    sourceDatabasesLoading.value = false
  }
}

const loadSourceCollections = async () => {
  sourceCollectionsLoading.value = true
  try {
    const resp = await axios.post('/api/explore/collections', {
      ...buildMongoConnectionPayload(sourceConnection),
      database: sourceConnection.database,
      collection: 'admin',
    })
    sourceCollections.value = resp.data.collections || []
  } catch (err: any) {
    sourceConnection.message = 'Erro ao carregar coleções.'
    sourceConnection.status = 'error'
  } finally {
    sourceCollectionsLoading.value = false
  }
}

const loadDestinationDatabases = async () => {
  destinationDatabasesLoading.value = true
  try {
    const resp = await axios.post('/api/explore/databases', {
      ...buildMongoConnectionPayload(destinationConnection),
      database: 'admin',
      collection: 'admin',
    })
    destinationDatabases.value = resp.data.databases || []
  } catch (err: any) {
    destinationConnection.message = 'Erro ao carregar bancos de dados.'
    destinationConnection.status = 'error'
  } finally {
    destinationDatabasesLoading.value = false
  }
}

const loadDestinationCollections = async () => {
  destinationCollectionsLoading.value = true
  try {
    const resp = await axios.post('/api/explore/collections', {
      ...buildMongoConnectionPayload(destinationConnection),
      database: destinationConnection.database,
      collection: 'admin',
    })
    destinationCollections.value = resp.data.collections || []
  } catch (err: any) {
    destinationConnection.message = 'Erro ao carregar coleções.'
    destinationConnection.status = 'error'
  } finally {
    destinationCollectionsLoading.value = false
  }
}

const viewSourceSample = async () => {
  sourceSamplesLoading.value = true
  sourceSamples.value = []
  sourceBaseDocument.value = null
  const previouslySelectedId = selectedSourceBaseDocumentId.value
  selectedSourceBaseDocumentId.value = ''
  try {
    const resp = await axios.post('/api/explore/sample', buildMongoConnectionPayload(sourceConnection))
    sourceSamples.value = resp.data.items || []

    if (useSelectedBaseDocument.value && previouslySelectedId) {
      const matching = sourceSamples.value.find((item) => getDocumentId(item) === previouslySelectedId)
      if (matching) {
        selectSourceBaseDocument(matching)
      }
    }

    syncMappingsFromSamples()
    if (sourceDocumentForMapping.value) {
      const mappedDocs = buildMappedDocuments(sourceDocumentForMapping.value)
      mappedPreviewDocument.value = mappedDocs.length > 0 ? mappedDocs[0] : null
    }
  } catch (err: any) {
    sourceConnection.message = err.response?.data?.detail || err.message || 'Erro ao buscar documentos.'
    sourceConnection.status = 'error'
  } finally {
    sourceSamplesLoading.value = false
  }
}

const viewDestinationSample = async () => {
  destinationSamplesLoading.value = true
  destinationSamples.value = []
  try {
    const resp = await axios.post('/api/explore/sample', buildMongoConnectionPayload(destinationConnection))
    destinationSamples.value = resp.data.items || []
    syncMappingsFromSamples()
    if (sourceDocumentForMapping.value) {
      const mappedDocs = buildMappedDocuments(sourceDocumentForMapping.value)
      mappedPreviewDocument.value = mappedDocs.length > 0 ? mappedDocs[0] : null
    }
  } catch (err: any) {
    destinationConnection.message = err.response?.data?.detail || err.message || 'Erro ao buscar documentos.'
    destinationConnection.status = 'error'
  } finally {
    destinationSamplesLoading.value = false
  }
}
</script>

