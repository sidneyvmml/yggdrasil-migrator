  margin-top: auto;
  display: grid;
  gap: 8px;
}

.global-env,
.global-user {
  border: 1px solid #334155;
  background: #111827;
  border-radius: 10px;
  color: #94a3b8;
  font-size: 0.82rem;
  padding: 9px;
}

.global-main {
  position: relative;
}

.global-main-header {
  position: sticky;
