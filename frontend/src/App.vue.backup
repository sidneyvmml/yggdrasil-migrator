  { day: 'Wed', ok: 52, warn: 16 },
  { day: 'Thu', ok: 80, warn: 10 },
  { day: 'Fri', ok: 66, warn: 18 },
  { day: 'Sat', ok: 45, warn: 11 },
  { day: 'Sun', ok: 62, warn: 13 },
]

const isMigrationFlowTab = computed(() => ['engines', 'connections', 'mapping', 'preview'].includes(activeTab.value))

const migrationStepDescription = computed(() => {
  if (activeTab.value === 'engines') {
    return 'Choose source and target engines for this migration path.'
  }
  if (activeTab.value === 'connections') {
    return 'Configure source and destination before field mapping.'
  }
  if (activeTab.value === 'mapping') {
    return 'Define mappings and transformations for the destination payload.'
  }
  if (activeTab.value === 'preview') {
    return 'Review the transformed payload before creating the migration job.'
  }
  return ''
})

const sourceConnection = reactive({
  connectionString: 'mongodb://localhost:27017',
