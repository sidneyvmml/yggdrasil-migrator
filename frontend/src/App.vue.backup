  Redis: new URL('./assets/redis.png', import.meta.url).href,
}

const getEngineLogo = (engineName: string) => engineLogoMap[engineName] || ''

const getEngineGlyph = (engineName: string) => engineGlyphMap[engineName] || '🗄'

const getPathEngineImage = (engineName: string) => {
  if (engineName === 'MongoDB') {
    return mongoPathImageUrl
  }
  if (engineName === 'PostgreSQL') {
    return postgresPathImageUrl
